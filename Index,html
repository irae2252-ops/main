<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CBMC 중국어 비전스쿨</title>
    
    <!-- 폰트: Noto Sans KR -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700&display=swap" rel="stylesheet">
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#007BFF', // 요청하신 포인트 색상
                        primaryHover: '#0056b3'
                    },
                    fontFamily: {
                        sans: ['"Noto Sans KR"', 'sans-serif'],
                    }
                }
            }
        }
    </script>

    <!-- 아이콘: Phosphor Icons -->
    <script src="https://unpkg.com/@phosphor-icons/web"></script>

    <style>
        html { scroll-behavior: smooth; }
        body { font-family: 'Noto Sans KR', sans-serif; color: #333; }
        .hero-bg {
            /* 업로드된 이미지를 메인 배경으로 설정 */
            background-image: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url('WhatsApp Image 2026-04-21 at 6.04.07 PM.jpeg');
            background-size: cover;
            background-position: center;
        }
    </style>
</head>
<body class="bg-white">

    <!-- 헤더 -->
    <header class="fixed w-full bg-white/90 backdrop-blur-sm shadow-sm z-50 transition-all duration-300" id="header">
        <div class="max-w-6xl mx-auto px-4 h-20 flex items-center justify-between">
            <!-- 로고 -->
            <a href="#" class="flex items-center gap-2 text-2xl font-bold text-primary">
                <i class="ph-fill ph-globe-hemisphere-east text-3xl"></i>
                CBMC <span class="text-gray-800 text-lg ml-1 font-medium">중국어 비전스쿨</span>
            </a>
            
            <!-- 네비게이션 메뉴 (PC) -->
            <nav class="hidden md:flex gap-8 font-medium">
                <a href="#hero" class="hover:text-primary transition">홈</a>
                <a href="#about" class="hover:text-primary transition">소개</a>
                <a href="#curriculum" class="hover:text-primary transition">교육과정</a>
                <a href="#booking" class="hover:text-primary transition">예약안내</a>
            </nav>

            <!-- 모바일 메뉴 버튼 -->
            <button class="md:hidden text-2xl" id="mobileMenuBtn">
                <i class="ph ph-list"></i>
            </button>
        </div>
        <!-- 모바일 메뉴 드롭다운 -->
        <div class="md:hidden hidden bg-white border-t" id="mobileMenu">
            <nav class="flex flex-col p-4 gap-4 font-medium">
                <a href="#hero" class="mobile-link">홈</a>
                <a href="#about" class="mobile-link">소개</a>
                <a href="#curriculum" class="mobile-link">교육과정</a>
                <a href="#booking" class="mobile-link">예약안내</a>
            </nav>
        </div>
    </header>

    <!-- 메인 (Hero Section) -->
    <section id="hero" class="hero-bg h-screen min-h-[600px] flex items-center justify-center text-center px-4 pt-20">
        <div class="max-w-4xl animate-fade-in-up text-white">
            <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6 break-keep">
                "일터를 하나님의 나라로 만들어가는<br class="hidden md:block"> 인큐베이터로 당신을 초대합니다"
            </h1>
            <p class="text-lg md:text-xl text-gray-200 mb-10 break-keep">
                CBMC 중국어 비전스쿨에서 새로운 정체성과 사명을 발견하세요.
            </p>
            <a href="#booking" class="inline-block bg-primary hover:bg-primaryHover text-white font-semibold py-4 px-8 rounded-full transition duration-300 shadow-lg text-lg">
                입소훈련 예약하기
            </a>
        </div>
    </section>

    <!-- 소개 (About Us) -->
    <section id="about" class="py-24 px-4 bg-gray-50">
        <div class="max-w-4xl mx-auto text-center">
            <div class="text-primary mb-4 flex justify-center">
                <i class="ph ph-hand-heart text-5xl"></i>
            </div>
            <h2 class="text-3xl md:text-4xl font-bold mb-8 text-gray-900">우리의 사명</h2>
            <p class="text-xl md:text-2xl text-gray-700 leading-relaxed font-light break-keep mb-8">
                "일터에서 하나님과 교제, 정체성, 비전, 공동체, <br class="hidden md:block"> 사명을 만나도록 섬깁니다."
            </p>
            <div class="inline-block bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
                <p class="text-lg font-medium text-gray-800">
                    <span class="text-primary font-bold text-2xl">30,000</span>명의 일터 리더 양성
                </p>
                <p class="text-gray-500 text-sm mt-1">하나님 나라의 비전을 품은 크리스천 비즈니스맨의 요람</p>
            </div>
        </div>
    </section>

    <!-- 교육과정 (Curriculum) -->
    <section id="curriculum" class="py-24 px-4 bg-white">
        <div class="max-w-5xl mx-auto">
            <h2 class="text-3xl md:text-4xl font-bold text-center mb-4 text-gray-900">교육과정</h2>
            <p class="text-center text-gray-500 mb-16 text-lg">2박 3일 입소훈련 커리큘럼</p>

            <div class="grid md:grid-cols-3 gap-8">
                <!-- 1일차 -->
                <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-lg transition-shadow">
                    <div class="w-14 h-14 bg-blue-100 text-primary rounded-full flex items-center justify-center text-xl font-bold mb-6">
                        Day 1
                    </div>
                    <h3 class="text-xl font-bold mb-4 text-gray-800">하나님과 교제</h3>
                    <ul class="text-gray-600 space-y-2 leading-relaxed">
                        <li class="flex gap-2 items-start"><i class="ph ph-check-circle text-primary mt-1"></i> 마음 열기 및 오리엔테이션</li>
                        <li class="flex gap-2 items-start"><i class="ph ph-check-circle text-primary mt-1"></i> 하나님과의 깊은 만남</li>
                        <li class="flex gap-2 items-start"><i class="ph ph-check-circle text-primary mt-1"></i> 개인 영성 회복의 시간</li>
                    </ul>
                </div>

                <!-- 2일차 -->
                <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-lg transition-shadow relative">
                    <div class="absolute -top-4 right-8 bg-primary text-white text-xs font-bold px-3 py-1 rounded-full">핵심과정</div>
                    <div class="w-14 h-14 bg-blue-100 text-primary rounded-full flex items-center justify-center text-xl font-bold mb-6">
                        Day 2
                    </div>
                    <h3 class="text-xl font-bold mb-4 text-gray-800">정체성과 비전</h3>
                    <ul class="text-gray-600 space-y-2 leading-relaxed">
                        <li class="flex gap-2 items-start"><i class="ph ph-check-circle text-primary mt-1"></i> 일터에서의 기독교 세계관</li>
                        <li class="flex gap-2 items-start"><i class="ph ph-check-circle text-primary mt-1"></i> 하나님이 주신 비전 발견</li>
                        <li class="flex gap-2 items-start"><i class="ph ph-check-circle text-primary mt-1"></i> 공동체 의식 함양</li>
                        <li class="flex gap-2 items-start"><i class="ph ph-check-circle text-primary mt-1"></i> 기독실업인의 성경적 경영 원리</li>
                    </ul>
                </div>

                <!-- 3일차 -->
                <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-lg transition-shadow">
                    <div class="w-14 h-14 bg-blue-100 text-primary rounded-full flex items-center justify-center text-xl font-bold mb-6">
                        Day 3
                    </div>
                    <h3 class="text-xl font-bold mb-4 text-gray-800">사명과 결단</h3>
                    <ul class="text-gray-600 space-y-2 leading-relaxed">
                        <li class="flex gap-2 items-start"><i class="ph ph-check-circle text-primary mt-1"></i> 비전 워크샵 (조별 활동)</li>
                        <li class="flex gap-2 items-start"><i class="ph ph-check-circle text-primary mt-1"></i> 개인 사명선언서 작성 및 발표</li>
                        <li class="flex gap-2 items-start"><i class="ph ph-check-circle text-primary mt-1"></i> 파송 예배 및 수료식</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- 예약 및 위치 (Booking & Location) -->
    <section id="booking" class="py-24 px-4 bg-gray-50">
        <div class="max-w-6xl mx-auto">
            <div class="grid lg:grid-cols-2 gap-12 bg-white rounded-3xl shadow-sm border border-gray-200 overflow-hidden">
                
                <!-- 예약 폼 -->
                <div class="p-8 md:p-12">
                    <h2 class="text-2xl md:text-3xl font-bold mb-2 text-gray-900">비전스쿨 예약하기</h2>
                    <p class="text-gray-500 mb-8">입소훈련 참가를 위해 아래 정보를 입력해 주세요.</p>
                    
                    <form id="bookingForm" class="space-y-6">
                        <div>
                            <label for="name" class="block text-sm font-medium text-gray-700 mb-2">이름</label>
                            <input type="text" id="name" required class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition" placeholder="홍길동">
                        </div>
                        <div>
                            <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">연락처</label>
                            <input type="tel" id="phone" required class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition" placeholder="010-0000-0000">
                        </div>
                        <div>
                            <label for="date" class="block text-sm font-medium text-gray-700 mb-2">방문(입소) 일자</label>
                            <input type="date" id="date" required class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition">
                        </div>
                        <button type="submit" class="w-full bg-primary hover:bg-primaryHover text-white font-bold py-4 rounded-lg transition duration-300 mt-4">
                            예약 신청 완료
                        </button>
                    </form>
                </div>

                <!-- 위치 및 정보 -->
                <div class="bg-gray-100 p-8 md:p-12 flex flex-col justify-center">
                    <h3 class="text-xl font-bold mb-8 text-gray-900">오시는 길 및 안내</h3>
                    
                    <div class="space-y-6">
                        <div class="flex items-start gap-4">
                            <div class="bg-white p-3 rounded-full text-primary shadow-sm"><i class="ph ph-phone text-xl"></i></div>
                            <div>
                                <p class="font-bold text-gray-900 mb-1">문의 및 연락처</p>
                                <p class="text-gray-600 text-lg">02-362-4680</p>
                            </div>
                        </div>
                        
                        <div class="flex items-start gap-4">
                            <div class="bg-white p-3 rounded-full text-primary shadow-sm"><i class="ph ph-clock text-xl"></i></div>
                            <div>
                                <p class="font-bold text-gray-900 mb-1">운영 시간</p>
                                <p class="text-gray-600">평일 오전 9:00 ~ 오후 7:00</p>
                            </div>
                        </div>

                        <div class="flex items-start gap-4">
                            <div class="bg-white p-3 rounded-full text-primary shadow-sm"><i class="ph ph-map-pin text-xl"></i></div>
                            <div>
                                <p class="font-bold text-gray-900 mb-1">위치</p>
                                <p class="text-gray-600 leading-relaxed mb-3">말레이시아 CBMC 모판기지 오피스</p>
                                <!-- 지도 앱 연동 버튼 (구글 맵 검색 URL 예시) -->
                                <a href="https://www.google.com/maps/search/Malaysia+CBMC" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm text-primary font-semibold hover:underline">
                                    <i class="ph ph-map-trifold"></i> 구글 맵에서 보기
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- 푸터 -->
    <footer class="bg-white border-t border-gray-200 py-8">
        <div class="max-w-6xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-4">
            <div class="text-gray-500 font-medium flex items-center gap-2">
                <i class="ph-fill ph-globe-hemisphere-east text-xl text-gray-400"></i> CBMC
            </div>
            <p class="text-sm text-gray-500">© 2026 CBMC. All rights reserved.</p>
        </div>
    </footer>

    <!-- 메시지 모달 (Alert 대체용) -->
    <div id="messageModal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-[100] backdrop-blur-sm opacity-0 transition-opacity duration-300">
        <div class="bg-white rounded-2xl p-8 max-w-sm w-full mx-4 transform scale-95 transition-transform duration-300 shadow-2xl text-center" id="modalContent">
            <div class="w-16 h-16 bg-blue-50 text-primary rounded-full flex items-center justify-center text-3xl mx-auto mb-4">
                <i class="ph ph-check-circle"></i>
            </div>
            <h3 class="text-xl font-bold mb-2 text-gray-900">예약 접수 완료</h3>
            <p class="text-gray-600 mb-6" id="modalText">신청하신 내용이 성공적으로 접수되었습니다. 빠른 시일 내에 연락드리겠습니다.</p>
            <button onclick="closeModal()" class="w-full bg-primary hover:bg-primaryHover text-white font-bold py-3 rounded-lg transition duration-300">
                확인
            </button>
        </div>
    </div>

    <!-- 스크립트 -->
    <script>
        // 모바일 메뉴 토글
        const mobileMenuBtn = document.getElementById('mobileMenuBtn');
        const mobileMenu = document.getElementById('mobileMenu');
        const mobileLinks = document.querySelectorAll('.mobile-link');

        mobileMenuBtn.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
        });

        // 모바일 메뉴 링크 클릭 시 메뉴 닫기
        mobileLinks.forEach(link => {
            link.addEventListener('click', () => {
                mobileMenu.classList.add('hidden');
            });
        });

        // 스크롤 시 헤더 그림자 효과
        window.addEventListener('scroll', () => {
            const header = document.getElementById('header');
            if (window.scrollY > 10) {
                header.classList.add('shadow-md');
            } else {
                header.classList.remove('shadow-md');
            }
        });

        // 폼 제출 처리 및 커스텀 모달 (Alert 대체)
        const bookingForm = document.getElementById('bookingForm');
        const messageModal = document.getElementById('messageModal');
        const modalContent = document.getElementById('modalContent');
        const modalText = document.getElementById('modalText');

        bookingForm.addEventListener('submit', (e) => {
            e.preventDefault(); // 기본 제출 방지
            
            const name = document.getElementById('name').value;
            modalText.innerHTML = `<span class="font-bold text-gray-900">${name}</span>님의 예약 신청이<br>성공적으로 접수되었습니다.`;
            
            // 모달 열기
            messageModal.classList.remove('hidden');
            messageModal.classList.add('flex');
            // 애니메이션 지연 적용
            setTimeout(() => {
                messageModal.classList.remove('opacity-0');
                modalContent.classList.remove('scale-95');
                modalContent.classList.add('scale-100');
            }, 10);
            
            // 폼 초기화
            bookingForm.reset();
        });

        // 모달 닫기 함수
        function closeModal() {
            messageModal.classList.add('opacity-0');
            modalContent.classList.remove('scale-100');
            modalContent.classList.add('scale-95');
            
            setTimeout(() => {
                messageModal.classList.add('hidden');
                messageModal.classList.remove('flex');
            }, 300); // transition 시간과 일치
        }
    </script>
</body>
</html>
